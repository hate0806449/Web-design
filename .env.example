# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ig_tracker

# ── Instagram App（從 Meta for Developers 拿）─────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ── Instagram 非官方 scraping cookie ─────────────────────────────────────────
# 從瀏覽器登入 IG，DevTools → Application → Cookies → instagram.com
# 複製 sessionid 跟 csrftoken 的值
IG_SESSION_ID=
IG_CSRF_TOKEN=

# Cron 排程驗證
CRON_SECRET=

# ── 本機 dev 用 ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
